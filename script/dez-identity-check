#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "$0")/.."

require_pattern() {
    local file="$1"
    local pattern="$2"
    local description="$3"

    if ! rg --quiet "$pattern" "$file"; then
        echo "Dez identity check failed: $description" >&2
        exit 1
    fi
}

reject_pattern() {
    local file="$1"
    local pattern="$2"
    local description="$3"

    if rg --quiet "$pattern" "$file"; then
        echo "Dez identity check failed: $description" >&2
        exit 1
    fi
}

require_multiline_pattern() {
    local file="$1"
    local pattern="$2"
    local description="$3"

    if ! rg --quiet --multiline --multiline-dotall "$pattern" "$file"; then
        echo "Dez identity check failed: $description" >&2
        exit 1
    fi
}

require_pattern crates/paths/src/paths.rs \
    '^pub const APP_NAME: &str = "Dez";' \
    'public application name is not Dez'
require_pattern crates/paths/src/paths.rs \
    '^pub const APP_STORAGE_NAME: &str = "Superzed";' \
    'the documented legacy storage boundary changed without a migration'
require_pattern crates/zed/Cargo.toml \
    '^version = "0\.0\.1"$' \
    'application version is not 0.0.1'
require_pattern crates/zed/Cargo.toml \
    '^default-run = "dez"$' \
    'default executable is not dez'
require_pattern crates/zed/Cargo.toml \
    '^name = "dez"$' \
    'the Dez binary target is missing'
require_pattern crates/zed/Cargo.toml \
    '^osx_url_schemes = \["dez"\]$' \
    'the stable bundle does not exclusively own the canonical dez URL scheme'
require_pattern assets/settings/default.json \
    '^  "auto_update": false,$' \
    'automatic binary updates are enabled by default'
require_pattern assets/settings/default.json \
    '^  "auto_connect": false,$' \
    'upstream cloud auto-connect is enabled by default'
require_pattern crates/zed/src/main.rs \
    'paths::APP_NAME == "Zed" && client::ClientSettings::get_global\(cx\)\.auto_connect' \
    'inherited settings can auto-connect Dez to the upstream Zed cloud'
require_pattern crates/zed/src/zed/mac_only_instance.rs \
    '^const DEZ_INSTANCE_PORT_BASE: u16 = 45737;$' \
    'Dez still shares official Zed macOS single-instance ports'
require_pattern crates/zed/src/zed/open_listener.rs \
    'format!\("dez-\{\}\.sock", \*RELEASE_CHANNEL_NAME\)' \
    'the Dez application listener socket is not product-isolated'
require_pattern crates/cli/src/main.rs \
    '"dez-\{\}\.sock"' \
    'the Dez CLI socket is not product-isolated'
require_pattern crates/zed/src/zed/edit_prediction_registry.rs \
    'EditPredictionProvider::Zed if paths::APP_NAME != "Zed" => None' \
    'the upstream Zed edit-prediction provider is reachable in Dez'
require_pattern crates/zed/src/zed/edit_prediction_registry.rs \
    'EditPredictionProvider::Mercury if paths::APP_NAME != "Zed" => None' \
    'the upstream Mercury edit-prediction provider is reachable in Dez'
require_multiline_pattern crates/zed/src/zed.rs \
    'let channels_panel = \(APP_NAME == "Zed"\)\.then\(\|\| \{.*?CollabPanel::load' \
    'Dez eagerly loads the upstream collaboration panel'
require_pattern crates/title_bar/src/title_bar.rs \
    'paths::APP_NAME == "Zed" && sidebar_settings.show_onboarding_banner' \
    'Dez can render upstream onboarding promotions in its title bar'
require_pattern crates/workspace/src/welcome.rs \
    'APP_NAME == "Zed" && !self.fallback_to_recent_projects' \
    'the Dez welcome surface can route back into upstream onboarding'
reject_pattern crates/workspace/src/welcome.rs \
    'IconName::ZedAssistant' \
    'the Dez getting-started surface still renders the Zed Assistant glyph'
require_pattern crates/zed/src/zed.rs \
    'should_seed_empty_workspace_with_blank_file\(app_name: &str\) -> bool' \
    'empty Dez viewports can bypass the actionable launch surface'
require_pattern crates/zed/src/zed.rs \
    'app_name == "Zed"' \
    'blank-file seeding is not restricted to the official Zed product'
require_pattern crates/workspace/src/multi_workspace.rs \
    'workspace\.mark_durable_session_present\(viewport_id, cx\);' \
    'background Workspace registration is absent from durable viewport composition'
require_pattern crates/sidebar/src/sidebar.rs \
    '"No sessions yet"\.to_owned\(\)' \
    'the zero-session overview still presents completed-work copy'
require_pattern crates/sidebar/src/sidebar.rs \
    'Button::new\("new-session", "New Terminal"\)' \
    'the primary Session Rail creation action is ambiguous'
require_pattern crates/sidebar/src/sidebar.rs \
    'Label::new\("Start working"\)' \
    'the empty Session Rail funnels terminal-native work into a project-first frame'
require_pattern crates/release_channel/src/lib.rs \
    'ReleaseChannel::Stable => "Dez"' \
    'stable release display name is not Dez'
require_pattern crates/release_channel/src/lib.rs \
    'ReleaseChannel::Stable => "dev\.dez\.Dez"' \
    'stable bundle identifier is not isolated'
require_multiline_pattern crates/release_channel/src/lib.rs \
    'pub fn poll_for_updates\(&self\) -> bool \{.*?\n        false\n    \}' \
    'the fork update gate no longer returns false'
require_pattern script/bundle-mac \
    'Contents/MacOS/dez' \
    'the macOS bundle does not package the Dez executable'
require_pattern crates/dez_terminal_host/Cargo.toml \
    '^name = "dez-terminal-host"$' \
    'the durable terminal helper binary target is missing'
require_pattern script/bundle-mac \
    'Contents/MacOS/dez-terminal-host' \
    'the macOS bundle does not package the durable terminal helper'
require_pattern crates/terminal/src/terminal.rs \
    'env\.insert\("DEZ_TERM"\.to_string\(\), "true"\.to_string\(\)\);' \
    'terminal sessions do not expose the Dez capability marker'
require_pattern crates/terminal/src/terminal.rs \
    'env\.insert\("TERM_PROGRAM"\.to_string\(\), "dez"\.to_string\(\)\);' \
    'terminal sessions do not identify TERM_PROGRAM as Dez'

reject_pattern crates/release_channel/src/lib.rs \
    'dev\.zed\.Zed' \
    'an official Zed bundle identifier is active in Dez release channels'
reject_pattern crates/zed/Cargo.toml \
    '^osx_url_schemes = .*"zed(-[a-z]+)?"' \
    'the Dez bundle still claims an official Zed URL scheme'
reject_pattern crates/install_cli/src/register_zed_scheme.rs \
    'ZED_URL_SCHEME|"zed(-[a-z]+)?"' \
    'the Dez installer still registers an official Zed URL scheme'
reject_pattern crates/install_cli/src/install_cli_binary.rs \
    '/usr/local/bin/zed|InstalledZedCli|Zed CLI' \
    'the Dez CLI installer still overwrites or presents the official Zed CLI'
reject_pattern crates/install_cli/src/install_cli_binary.rs \
    'installed Zed|zeditor|zedit|zed-editor' \
    'the Dez CLI installer still gives upstream package guidance'
require_multiline_pattern crates/zed/src/zed/app_menus.rs \
    'if APP_NAME != "Zed" \{.*?"Install CLI"' \
    'the Dez application menu does not expose its isolated CLI installer'
require_multiline_pattern crates/zed/src/zed.rs \
    'if APP_NAME == "Zed" \{.*?Official Zed CLI is not managed by this fork.*?return;' \
    'the fork CLI action can overwrite the official Zed command'
reject_pattern crates/zed/src/zed.rs \
    'does not install a global CLI shim in this build' \
    'the reachable Dez CLI action is still disabled'
reject_pattern crates/cli/src/main.rs \
    'Generate shell completions for Zed|Run zed in dev-server mode|Uninstall Zed from user system|Zed will attempt to open the paths directly' \
    'the Dez CLI help still presents the local product as Zed'
reject_pattern crates/cli/src/main.rs \
    'Handshake (before|after) Zed spawn' \
    'the Dez CLI reports launch-handshake failures as Zed failures'
reject_pattern crates/cli/src/main.rs \
    'visible_alias = "zed"' \
    'the Dez CLI exposes its legacy Zed compatibility alias in help'
reject_pattern crates/cli/src/main.rs \
    '"\.\./libexec/zed-editor"|"\.\./lib/zed/zed-editor"|"\./zed"|"\.\./Zed\.exe"|"\.\./lib/zed/zed-editor\.exe"|"\./zed\.exe"' \
    'Dez CLI autodetection can silently launch an official Zed executable'
require_pattern crates/cli/src/main.rs \
    'long = "dez", alias = "zed", value_name = "PATH"' \
    'the Dez CLI custom-app flag can expose a stale Zed metavar'
reject_pattern crates/terminal/src/terminal.rs \
    'env\.insert\("TERM_PROGRAM"\.to_string\(\), "zed"\.to_string\(\)\);' \
    'terminal sessions still identify the public product as Zed'
reject_pattern crates/oauth_callback_server/src/oauth_callback_server.rs \
    '<div class="brand">Zed</div>|return to Zed' \
    'the OAuth browser handoff still presents the local product as Zed'
reject_pattern crates/extensions_ui/src/extensions_ui.rs \
    'built-in to Zed|built into Zed|version of Zed' \
    'the extension surface still presents the local product as Zed'
reject_pattern crates/open_router/src/open_router.rs \
    '"X-Title", "Zed Editor"' \
    'OpenRouter requests still identify the local product as Zed'
reject_pattern crates/edit_prediction/src/zeta.rs \
    'ErrorAction::link\("Update Zed"' \
    'an upstream Zed installer is still offered as a Dez recovery action'
reject_pattern crates/system_specs/src/system_specs.rs \
    '"Zed: v\{\}' \
    'system diagnostics still label the running product as Zed'

echo "Dez identity checks passed"
