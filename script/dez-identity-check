#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "$0")/.."

require_pattern() {
    local file="$1"
    local pattern="$2"
    local description="$3"

    if ! rg --quiet "$pattern" "$file"; then
        echo "Dez identity check failed: $description" >&2
        exit 1
    fi
}

reject_pattern() {
    local file="$1"
    local pattern="$2"
    local description="$3"

    if rg --quiet "$pattern" "$file"; then
        echo "Dez identity check failed: $description" >&2
        exit 1
    fi
}

require_multiline_pattern() {
    local file="$1"
    local pattern="$2"
    local description="$3"

    if ! rg --quiet --multiline --multiline-dotall "$pattern" "$file"; then
        echo "Dez identity check failed: $description" >&2
        exit 1
    fi
}

