#!/usr/bin/env node

const fs = require("fs");
const path = require("path");

const root = path.resolve(__dirname, "..");
const themePath = path.join(root, "assets/themes/lumin/lumin.json");
const defaultSettingsPath = path.join(root, "assets/settings/default.json");
const initialSettingsPath = path.join(root, "assets/settings/initial_user_settings.json");

function fail(message) {
  console.error(`Dez theme check failed: ${message}`);
  process.exit(1);
}

function requireValue(condition, message) {
  if (!condition) fail(message);
}

function parseHex(color) {
  const value = color.replace("#", "");
  requireValue(value.length === 6 || value.length === 8, `unsupported color ${color}`);
  return {
    red: Number.parseInt(value.slice(0, 2), 16) / 255,
    green: Number.parseInt(value.slice(2, 4), 16) / 255,
    blue: Number.parseInt(value.slice(4, 6), 16) / 255,
    alpha: value.length === 8 ? Number.parseInt(value.slice(6, 8), 16) / 255 : 1,
  };
}

function parseColor(color) {
  return typeof color === "string" ? parseHex(color) : color;
}

function composite(foreground, background) {
  const foregroundColor = parseColor(foreground);
  const backgroundColor = parseColor(background);
  const alpha = foregroundColor.alpha + backgroundColor.alpha * (1 - foregroundColor.alpha);
  requireValue(alpha > 0, "cannot composite two fully transparent colors");
  return {
    red:
      (foregroundColor.red * foregroundColor.alpha +
        backgroundColor.red * backgroundColor.alpha * (1 - foregroundColor.alpha)) /
      alpha,
    green:
      (foregroundColor.green * foregroundColor.alpha +
        backgroundColor.green * backgroundColor.alpha * (1 - foregroundColor.alpha)) /
      alpha,
    blue:
      (foregroundColor.blue * foregroundColor.alpha +
        backgroundColor.blue * backgroundColor.alpha * (1 - foregroundColor.alpha)) /
      alpha,
    alpha,
  };
}

function channelLuminance(channel) {
  return channel <= 0.03928 ? channel / 12.92 : ((channel + 0.055) / 1.055) ** 2.4;
}

function luminance(color) {
  return (
    channelLuminance(color.red) * 0.2126 +
    channelLuminance(color.green) * 0.7152 +
    channelLuminance(color.blue) * 0.0722
  );
}

function contrast(foreground, background) {
  const backgroundColor = parseColor(background);
  requireValue(backgroundColor.alpha === 1, "contrast background must be opaque");
  const foregroundLuminance = luminance(composite(foreground, backgroundColor));
  const backgroundLuminance = luminance(backgroundColor);
  return (
    (Math.max(foregroundLuminance, backgroundLuminance) + 0.05) /
    (Math.min(foregroundLuminance, backgroundLuminance) + 0.05)
  );
}

function describeColor(color) {
  if (typeof color === "string") return color;
  const channel = (value) =>
    Math.round(value * 255)
      .toString(16)
      .padStart(2, "0")
      .toUpperCase();
  return `#${channel(color.red)}${channel(color.green)}${channel(color.blue)}`;
}

function requireContrast(label, foreground, backgrounds, minimum) {
  for (const background of backgrounds) {
    const ratio = contrast(foreground, background);
    requireValue(
      ratio >= minimum,
      `${label} is ${ratio.toFixed(2)}:1 on ${describeColor(background)}; expected at least ${minimum}:1`,
    );
  }
}

const themeDocument = JSON.parse(fs.readFileSync(themePath, "utf8"));
const themeByName = new Map(themeDocument.themes.map((theme) => [theme.name, theme]));
const luminBlur = themeByName.get("Lumin Blur");
const luminOpaque = themeByName.get("Lumin");
const luminLight = themeByName.get("Lumin Light");

requireValue(luminBlur?.appearance === "dark", "Lumin Blur must be dark");
requireValue(
  luminBlur?.style["background.appearance"] === "blurred",
  "Lumin Blur must request the blurred window shell",
);
requireValue(luminOpaque?.style["background.appearance"] === "opaque", "Lumin must remain the opaque dark fallback");
requireValue(luminLight?.appearance === "light", "Lumin Light must be light");
requireValue(
  luminLight?.style["background.appearance"] === "blurred",
  "Lumin Light must request the blurred window shell",
);

const darkTextTokens = [
  "text",
  "text.muted",
  "text.placeholder",
  "text.accent",
  "editor.foreground",
  "editor.line_number",
  "editor.active_line_number",
  "error",
  "success",
  "warning",
  "modified",
  "renamed",
  "conflict",
  "created",
  "deleted",
  "link_text.hover",
  "terminal.foreground",
  "terminal.bright_foreground",
  "terminal.dim_foreground",
  "terminal.ansi.black",
  "terminal.ansi.red",
  "terminal.ansi.green",
  "terminal.ansi.yellow",
  "terminal.ansi.blue",
  "terminal.ansi.magenta",
  "terminal.ansi.cyan",
  "terminal.ansi.white",
  "terminal.ansi.bright_black",
  "terminal.ansi.bright_red",
  "terminal.ansi.bright_green",
  "terminal.ansi.bright_yellow",
  "terminal.ansi.bright_blue",
  "terminal.ansi.bright_magenta",
  "terminal.ansi.bright_cyan",
  "terminal.ansi.bright_white",
];
const darkFocusTokens = ["border.focused", "border.selected", "panel.focused_border", "pane.focused_border"];
const darkControlSurfaces = [
  "element.background",
  "element.hover",
  "element.active",
  "element.selected",
  "ghost_element.hover",
  "ghost_element.active",
  "ghost_element.selected",
  "editor.active_line.background",
  "editor.highlighted_line.background",
  "editor.selection.background",
  "search.match_background",
  "search.active_match_background",
];

function requireDarkThemeContrast(theme, surfaces) {
  const style = theme.style;

  requireValue(
    style.syntax.boolean.color === style.syntax.constant.color,
    `${theme.name} booleans and constants must retain one neutral hierarchy`,
  );
  requireValue(
    style.syntax["function.special.definition"].color === style.syntax.function.color,
    `${theme.name} special-function definitions must retain the established function color`,
  );
  requireValue(
    style["terminal.ansi.black"] !== style["terminal.ansi.bright_black"],
    `${theme.name} terminal black and bright black must remain distinguishable`,
  );

  for (const token of darkTextTokens) {
    requireContrast(`${theme.name}.${token}`, style[token], surfaces, 4.5);
  }
  for (const token of ["icon", "icon.muted", "icon.accent"]) {
    requireContrast(`${theme.name}.${token}`, style[token], surfaces, 3);
  }
  for (const token of darkFocusTokens) {
    requireContrast(`${theme.name}.${token}`, style[token], surfaces, 3);
  }
  for (const token of darkControlSurfaces) {
    if (!style[token]) continue;
    const controlBackgrounds = surfaces.map((surface) => composite(style[token], surface));
    requireContrast(`${theme.name}.${token} text`, style.text, controlBackgrounds, 4.5);
  }
  for (const [token, syntaxStyle] of Object.entries(style.syntax)) {
    if (syntaxStyle.color) {
      requireContrast(`${theme.name}.syntax.${token}`, syntaxStyle.color, surfaces, 4.5);
    }
  }
}

const opaqueDarkSurfaces = ["#101010", "#161616"];
const blurredDarkSurfaces = [
  composite(luminBlur.style.background, "#000000"),
  composite(luminBlur.style.background, "#303030"),
  parseHex("#161616"),
];
requireDarkThemeContrast(luminBlur, blurredDarkSurfaces);
requireDarkThemeContrast(luminOpaque, opaqueDarkSurfaces);

const light = luminLight.style;
const lightSurfaces = ["#FFFFFF", "#F5F5F5"];

requireContrast("active control text", light.text, [light["element.active"]], 4.5);
requireContrast("accent text", light["text.accent"], lightSurfaces, 4.5);
requireContrast("focused border", light["border.focused"], lightSurfaces, 3);
requireContrast("placeholder text", light["text.placeholder"], lightSurfaces, 4.5);
requireContrast("editor line number", light["editor.line_number"], lightSurfaces, 4.5);

for (const token of [
  "error",
  "success",
  "warning",
  "modified",
  "renamed",
  "conflict",
  "link_text.hover",
  "terminal.foreground",
  "terminal.dim_foreground",
  "terminal.ansi.red",
  "terminal.ansi.green",
  "terminal.ansi.yellow",
  "terminal.ansi.blue",
  "terminal.ansi.magenta",
  "terminal.ansi.cyan",
  "terminal.ansi.white",
]) {
  requireContrast(token, light[token], lightSurfaces, 4.5);
}

for (const [token, style] of Object.entries(light.syntax)) {
  if (style.color) {
    requireContrast(`syntax.${token}`, style.color, lightSurfaces, 4.5);
  }
}

const defaultSettings = fs.readFileSync(defaultSettingsPath, "utf8");
const initialSettings = fs.readFileSync(initialSettingsPath, "utf8");
for (const settings of [defaultSettings, initialSettings]) {
  requireValue(settings.includes('"light": "Lumin Light"'), "light default must select Lumin Light");
  requireValue(settings.includes('"dark": "Lumin Blur"'), "dark default must select Lumin Blur");
  requireValue(
    settings.includes('"buffer_font_family": "JetBrains Mono"'),
    "editor default must select JetBrains Mono",
  );
  requireValue(
    settings.includes('"ui_font_family": ".ZedSans"'),
    "UI default must retain the readable bundled sans-serif face",
  );
}
requireValue(
  defaultSettings.includes('"font_family": "JetBrains Mono"') &&
    initialSettings.includes('"font_family": "JetBrains Mono"'),
  "terminal default must select JetBrains Mono",
);
requireValue(
  defaultSettings.includes('"markdown_preview_code_font_family": "JetBrains Mono"'),
  "Markdown code must select JetBrains Mono",
);

for (const file of [
  "JetBrainsMono-Regular.ttf",
  "JetBrainsMono-Italic.ttf",
  "JetBrainsMono-Bold.ttf",
  "JetBrainsMono-BoldItalic.ttf",
]) {
  requireValue(fs.existsSync(path.join(root, "assets/fonts/jetbrains-mono", file)), `missing bundled font ${file}`);
}

console.log("Dez theme checks passed");
